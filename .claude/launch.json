{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "backend-full",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["start", "--prefix", "backend"],
      "port": 0,
      "autoPort": true
    },
    {
      "name": "backend-api",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "api", "--prefix", "backend"],
      "port": 0
    },
    {
      "name": "backend-dev",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--prefix", "backend"],
      "port": 0
    }
  ]
}
