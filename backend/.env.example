# SIGNA — local environment (free tier)

# API server
PORT=4000

# Watchlist — comma-separated. Real tickers only. Yahoo free tier is generous but not infinite.
WATCHLIST=AAPL,NVDA,TSLA,AMD,SOFI,AMZN,GME,MSFT,META,GOOGL

# Scan cadence (minutes)
MARKET_SCAN_INTERVAL_MIN=5
SOCIAL_SCAN_INTERVAL_MIN=2

# Subreddits to monitor (free Reddit JSON)
REDDIT_SUBS=wallstreetbets,stocks,investing,cryptocurrency

# Primary market-data provider — Massive.com (free 5 req/min, 15-min delayed)
MASSIVE_API_KEY=

# Fallback provider — TwelveData (free 800/day, used only for search bar)
TWELVE_DATA_KEY=

# Stooq — optional free tier, now captcha-gated; safe to leave empty
STOOQ_API_KEY=

# Strict mode: 1 = fail if no live data (recommended). 0 = allow synthetic fallback.
SIGNA_STRICT=1

# Optional (leave empty for free tier)
POLYGON_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# DB path (SQLite). On Render/Fly use an absolute path inside a persistent disk.
DB_PATH=./signa.db
